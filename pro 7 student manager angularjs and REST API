app.js

var app = angular.module("studentApp", []);

/* SERVICE */
app.service("StudentService", function($http){

    var api = "https://jsonplaceholder.typicode.com/users";

    this.getStudents = function(){
        return $http.get(api);
    };

    this.addStudent = function(student){
        return $http.post(api, student);
    };

    this.deleteStudent = function(id){
        return $http.delete(api + "/" + id);
    };

});


/* CONTROLLER */
app.controller("StudentController", function($scope, StudentService){

    $scope.students = [];

    /* GET */
    StudentService.getStudents().then(function(response){
        $scope.students = response.data.slice(0,5); 
    });

    /* POST */
    $scope.addStudent = function(){

        StudentService.addStudent($scope.newStudent)
        .then(function(response){

            $scope.students.push(response.data);

            $scope.newStudent = {};
        });

    };

    /* DELETE */
    $scope.deleteStudent = function(id){

        StudentService.deleteStudent(id)
        .then(function(){

            $scope.students = $scope.students.filter(function(student){
                return student.id !== id;
            });

        });

    };

});
